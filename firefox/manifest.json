{
  "manifest_version": 2,
  "name": "UmbraChat",
  "version": "0.1.5",
  "description": "Ephemeral private P2P room chat with audio, video, and screen share.",
  "browser_action": {
    "default_title": "UmbraChat",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "clipboardWrite", "clipboardRead", "<all_urls>"],
  "browser_specific_settings": {
    "gecko": {
      "id": "umbrachat@jerry-1de",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["personalCommunications"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
